    "wealth_management": {
      "description": "Wealth management, financial advisory, venture capital \u2014 revenue is fee % of AUM",
      "revenue_formula": "AUM_acquired \u00d7 fee_percentage",
      "revenue_field": "revenue",
      "required_columns": [
        "leads",
        "cpl",
        "qualified",
        "cpql",
        "deals",
        "revenue"
      ],
      "ecom_columns": false,
      "rules": [
        "Revenue MUST equal approximately 1% of total AUM acquired (standard management fee)",
        "AUM per client typically $500K-$5M for HNW, $100K-$500K for mass affluent",
        "Monthly revenue = annual fee from clients closed that month (1% of their AUM)",
        "Total revenue across all months must \u2248 1% of total AUM in headline/hero",
        "ROAS will be low in early months (sub-1x is normal) \u2014 value is in retention",
        "Average client retention is 7-10 years \u2014 note projected LTV in impact section",
        "Hero stats MUST lead with AUM, not revenue"
      ],
      "fee_percentage": 0.01,
      "tolerance": 0.05
    },
    "real_estate": {
      "description": "Real estate brokerages and agents \u2014 revenue from commissions",
      "revenue_formula": "deals \u00d7 avg_transaction_value \u00d7 commission_rate",
      "revenue_field": "revenue",
      "required_columns": [
        "leads",
        "cpl",
        "qualified",
        "cpql",
        "deals",
        "revenue"
      ],
      "ecom_columns": false,
      "rules": [
        "Revenue = closed transactions \u00d7 avg home price \u00d7 commission rate (2.5-3%)",
        "Average home price varies heavily by market \u2014 MUST research local market",
        "Commercial RE: commission is typically 3-6% of lease value or 1-3% of sale price",
        "Sales cycle: 30-90 days residential, 3-12 months commercial",
        "Lead volume is high but close rate is low (2-5% from lead to close)"
      ],
      "commission_rate_range": [
        0.025,
        0.06
      ]
    },
    "mortgage_lending": {
      "description": "Mortgage brokers and lenders \u2014 revenue from origination fees and loan volume",
      "revenue_formula": "loans_closed \u00d7 avg_loan_amount \u00d7 origination_fee_pct",
      "revenue_field": "revenue",
      "required_columns": [
        "leads",
        "cpl",
        "qualified",
        "cpql",
        "deals",
        "revenue"
      ],
      "ecom_columns": false,
      "rules": [
        "Revenue = loans closed \u00d7 average loan amount \u00d7 origination fee (0.5-1.5%)",
        "OR revenue = loans closed \u00d7 flat fee per loan ($2K-$5K typical)",
        "Average loan amount varies by market \u2014 research local home prices",
        "Close rate from application to funded: 40-60%",
        "Close rate from lead to funded: 5-15%",
        "Seasonal: spring/summer peaks, winter dips"
      ]
    },
    "healthcare_medical": {
      "description": "Medical practices, med spas, telemedicine, regenerative medicine",
      "revenue_formula": "patients \u00d7 avg_treatment_value",
      "revenue_field": "revenue",
      "required_columns": [
        "leads",
        "cpl",
        "qualified",
        "cpql",
        "deals",
        "revenue"
      ],
      "ecom_columns": false,
      "rules": [
        "Revenue = new patients/clients \u00d7 average treatment/procedure value",
        "Med spa: avg treatment $300-$1,500",
        "Regenerative medicine: avg treatment $2,000-$10,000",
        "Telemedicine: avg consultation $100-$300",
        "Dental: avg patient value $800-$3,000/year",
        "Patient LTV often 3-5x initial visit value \u2014 can note in impact section",
        "Insurance vs cash-pay matters: cash-pay practices have higher margins"
      ]
    },
    "saas": {
      "description": "SaaS and subscription platforms \u2014 revenue from MRR/ARR",
      "revenue_formula": "new_customers \u00d7 avg_MRR \u00d7 months_retained OR annual_contracts \u00d7 ACV",
      "revenue_field": "revenue",
      "required_columns": [
        "leads",
        "cpl",
        "qualified",
        "cpql",
        "deals",
        "revenue"
      ],
      "ecom_columns": false,
      "rules": [
        "Revenue should be recognizable as ARR/ACV-derived",
        "B2B SaaS avg deal: $5K-$100K+ ACV depending on market segment",
        "SMB SaaS: $1K-$10K ACV",
        "Enterprise: $50K-$500K+ ACV",
        "Free trial \u2192 paid conversion: 5-15%",
        "Demo \u2192 close rate: 15-30%",
        "Churn matters: note net revenue retention if relevant"
      ]
    },
    "ecommerce": {
      "description": "Online retail / DTC brands \u2014 revenue from orders",
      "revenue_formula": "orders \u00d7 AOV",
      "revenue_field": "revenue",
      "required_columns_override": true,
      "ecom_columns": true,
      "column_labels": {
        "leads": "Sessions",
        "cpl": "Cost/Visit",
        "qualified": "Add to Carts",
        "cpql": "Cost/Cart",
        "deals": "Orders"
      },
      "rules": [
        "MUST use columnLabels to rename leads\u2192Sessions, cpl\u2192Cost/Visit, qualified\u2192Add to Carts, cpql\u2192Cost/Cart, deals\u2192Orders",
        "Revenue = orders \u00d7 AOV (with realistic variance month to month)",
        "AOV MUST be researched for the specific product category",
        "Session \u2192 Add to Cart rate: typically 5-15%",
        "Cart \u2192 Order rate: typically 30-70%",
        "Cost per visit: typically $0.50-$3.00",
        "ROAS: typically 2x-8x depending on margins and AOV",
        "Black Friday/Cyber Monday is MANDATORY if engagement includes November",
        "NO lead gen terminology anywhere \u2014 no 'leads', 'qualified leads', 'CPL', 'CPQL'",
        "Seasonal spend MUST vary \u2014 peak months get more budget"
      ],
      "aov_ranges": {
        "fashion_apparel": [
          40,
          120
        ],
        "luxury_fashion": [
          150,
          500
        ],
        "athletic_apparel": [
