        ]
      }
    },
    "subscription": {
      "description": "Subscription/membership businesses (non-SaaS) \u2014 yoga, education, newsletters",
      "revenue_formula": "new_subscribers \u00d7 monthly_price \u00d7 avg_months_retained",
      "revenue_field": "revenue",
      "rules": [
        "Revenue should reflect subscription economics \u2014 recurring monthly value",
        "Track subscriber acquisition cost vs LTV",
        "Monthly churn rate matters: 3-8% for consumer subscriptions",
        "Free trial conversion: 10-25%",
        "Annual vs monthly pricing affects revenue recognition"
      ]
    },
    "nonprofit": {
      "description": "Nonprofits \u2014 donations, grants, event revenue",
      "revenue_formula": "donors \u00d7 avg_donation OR event_revenue",
      "revenue_field": "revenue",
      "rules": [
        "Revenue = donations generated, not profit",
        "Donor acquisition cost is a key metric",
        "Recurring donor rate matters more than one-time donations",
        "Grant revenue should be separate from individual donations"
      ]
    }
  },
